# Copy to .env and adjust. See Settings in src/vcenter_event_assistant/settings.py

# --- Database (pick one) ---

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vcenter_event_assistant

# SQLite file (single-node / dev; ensure aiosqlite is installed — included in project deps)
DATABASE_URL=sqlite+aiosqlite:///./data/vea.db

# SQLite in-memory (tests / ephemeral)
# DATABASE_URL=sqlite+aiosqlite:///:memory:

# --- Optional auth (leave unset for no auth in trusted networks) ---
# AUTH_BEARER_TOKEN=
# AUTH_BASIC_USERNAME=
# AUTH_BASIC_PASSWORD=

# SCHEDULER_ENABLED=true
# CORS_ORIGINS=http://localhost:5173
