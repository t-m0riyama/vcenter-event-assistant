# Copy to .env and adjust. See Settings in src/vcenter_event_assistant/settings.py

# --- Database (pick one) ---

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vcenter_event_assistant

# SQLite file (single-node / dev; ensure aiosqlite is installed — included in project deps)
DATABASE_URL=sqlite+aiosqlite:///./data/vea.db

# SQLite in-memory (tests / ephemeral)
# DATABASE_URL=sqlite+aiosqlite:///:memory:

# --- Docker Compose（docker-compose.postgres.yml を docker-compose.yml にコピーした場合）---
# postgres サービスと app の DATABASE_URL で共通。省略時は compose 内の既定 vea。
# POSTGRES_PASSWORD=changeme

# SCHEDULER_ENABLED=true
# CORS_ORIGINS=http://localhost:5173

# --- Logging（任意。未設定ならコンソールのみ）---
# LOG_LEVEL=INFO
# アプリ本体（vcenter_event_assistant）と uvicorn（起動・アクセス等）を別ファイルに出す例
# APP_LOG_FILE=
# UVICORN_LOG_FILE=
# Docker Compose（sqlite / postgres）では `vea_logs:/var/log/vea` をマウントし、compose 側で次を既定にしている:
# APP_LOG_FILE=/var/log/vea/app.log
# UVICORN_LOG_FILE=/var/log/vea/uvicorn.log

# --- Data retention (days; purge runs on a schedule) ---
# EVENT_RETENTION_DAYS=7
# METRIC_RETENTION_DAYS=7

# --- Batch digest (Markdown; optional LLM summary) ---
# カスタム Jinja テンプレでは要注意イベントは `ctx.top_notable_event_groups`（種別集約）。旧 `ctx.top_notable_events` は廃止。
# APScheduler での自動生成（`SCHEDULER_ENABLED=true` かつアプリ起動時にスケジューラが載ること）
#
# 日次・週次・月次はそれぞれ ON/OFF と cron を個別指定（推奨）
# DIGEST_DAILY_ENABLED=false
# DIGEST_DAILY_CRON=0 7 * * *
# DIGEST_WEEKLY_ENABLED=false
# 週次の既定例: 毎週月曜 8:00。5 フィールドは「分 時 日 月 曜」。APScheduler の曜日は Python weekday と同じ 0=月曜…6=日曜（Unix cron の 0/7=日曜とは異なり、7 は無効）。日曜にしたい場合は最後を 6。時刻・曜日は `from_crontab` がプロセスのローカル TZ で解釈する（未指定のため UTC 固定ではない）
# DIGEST_WEEKLY_CRON=0 8 * * 0
# DIGEST_MONTHLY_ENABLED=false
# 例: 毎月 1 日 00:05 UTC
# DIGEST_MONTHLY_CRON=5 0 1 * *
#
# 後方互換（非推奨）: 下記は日次の実効有効/cron にマップされる（`effective_digest_daily_*`）
# DIGEST_SCHEDULER_ENABLED=false
# DIGEST_CRON=0 7 * * *

# LLM — ダイジェストは LLM_DIGEST_* のみ参照。チャットは任意の LLM_CHAT_* で上書き（未設定フィールドは LLM_DIGEST_* にフォールバック）。
# 旧プレフィックス LLM_*（LLM_API_KEY 等）は廃止。移行例: LLM_API_KEY → LLM_DIGEST_API_KEY、LLM_MODEL → LLM_DIGEST_MODEL。
# LLM_DIGEST_PROVIDER=openai_compatible
# LLM_DIGEST_PROVIDER=gemini
# LLM_DIGEST_API_KEY=
# OpenAI 互換時のみ（Chat Completions: POST {LLM_DIGEST_BASE_URL}/chat/completions）
# LLM_DIGEST_BASE_URL=https://api.openai.com/v1
# LLM_DIGEST_MODEL=gpt-4o-mini
# Gemini 時は Google AI Studio のキーを LLM_DIGEST_API_KEY に。例: gemini-2.0-flash
# LLM_DIGEST_TIMEOUT_SECONDS=60
# チャットだけ別モデル・別キーにする例（省略時はダイジェストと同じ実効値）
# LLM_CHAT_PROVIDER=
# LLM_CHAT_API_KEY=
# LLM_CHAT_BASE_URL=
# LLM_CHAT_MODEL=
# LLM_CHAT_TIMEOUT_SECONDS=
# --- GitHub Copilot CLI（チャット専用・LLM_CHAT_PROVIDER=copilot_cli）---
# LLM_DIGEST_PROVIDER に copilot_cli は指定できない（チャットのみ。設定すると検証エラー）。
# 同一ホストに Copilot CLI と GitHub 認証が必要。本番 Docker では運用が難しい場合がある。
# LLM_CHAT_PROVIDER=copilot_cli
# LLM_CHAT_API_KEY=ghp_...  （実効チャットキーとして GitHub トークンを使用）
# LLM_CHAT_MODEL=gpt-4.1    （CLI が解釈するモデル ID。環境により異なる）
# LLM_COPILOT_CLI_PATH=     （任意。空なら PATH の copilot または SDK 同梱バイナリ）
# LLM_COPILOT_CLI_SESSION_AUTH=false  （true のとき SDK に PAT を渡さず gh auth login 等の CLI セッションのみ。PAT 拒否エラー時に true）
# チャット LLM の入力全体（システム＋集約 JSON＋会話）の目安トークン上限（tiktoken cl100k_base）。Gemini とは一致しない場合あり。
# LLM_CHAT_MAX_INPUT_TOKENS=32000
# LLM 入力の識別子匿名化（チャット・ダイジェスト）。既定 true。false でオフ（開発・検証用）。応答はサーバ側で逆変換し UI / 保存本文は実名のまま。
# LLM_ANONYMIZATION_ENABLED=true
#
# LangSmith（任意。既定はオフ。オンにするとトレース用にプロンプトがクラウドに送られる可能性あり）
# LANGSMITH_TRACING_ENABLED=false
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=
# LANGSMITH_ENDPOINT=
# ローカル Ollama は初回・長いプロンプトで既定 60 秒を超えることがある。ReadTimeout なら値を大きくする（上限 7200）。
# 変更後は API プロセスを再起動すること（Settings は起動時に読み込み・キャッシュされる）。
#
# --- Ollama などローカルの OpenAI 互換 API（LLM_DIGEST_PROVIDER は openai_compatible のまま）---
# 本アプリは chat/completions を stream モードで呼ぶ（Ollama が非ストリーミング長生成を約 2 分で打ち切り 500 にすることがあるため）。
# Ollama は既定で http://127.0.0.1:11434/v1 に互換エンドポイントを提供する（モデルは事前に ollama pull）。
# LLM_DIGEST_BASE_URL=http://127.0.0.1:11434/v1
# LLM_DIGEST_MODEL=llama3.2
# LLM_DIGEST_MODEL はホストで `ollama list` に出る名前と一致させる（未 pull / 誤記だと HTTP 4xx やモデル未検出になる）。
# LLM_DIGEST_API_KEY は空だと LLM を呼ばない。Ollama はキー不要でも、非空のダミー（例: ollama）を入れること。
# Docker 内の app からホストの Ollama へ繋ぐ例（Docker Desktop の macOS/Windows 想定）:
# LLM_DIGEST_BASE_URL=http://host.docker.internal:11434/v1

# ダイジェスト本文の Jinja2 テンプレ（省略時はパッケージ同梱の digest.md.j2）
# 解決順（kind ごと）:
#   1) kind が weekly かつ DIGEST_TEMPLATE_WEEKLY_PATH が非空 → そのファイル（不可ならエラー・他へは落とさない）
#   2) kind が monthly かつ DIGEST_TEMPLATE_MONTHLY_PATH が非空 → そのファイル（同上）
#   3) 上記以外 → DIGEST_TEMPLATE_PATH（非空かつファイルでない場合はエラー・DIR には落とさない）
#   → DIGEST_TEMPLATE_DIR + DIGEST_TEMPLATE_FILE（ファイル不可ならエラー・同梱には落とさない）
#   → 同梱テンプレ。各 run_digest 実行ごとにディスクから読み直す。相対パスはプロセスの cwd 基準。
# DIGEST_TEMPLATE_WEEKLY_PATH=
# DIGEST_TEMPLATE_MONTHLY_PATH=
# DIGEST_TEMPLATE_PATH=
# DIGEST_TEMPLATE_DIR=
# DIGEST_TEMPLATE_FILE=digest.md.j2
# ダイジェスト本文の日時表示と、日次・週次・月次の集計ウィンドウの暦境界（無効な IANA 名は UTC にフォールバックして警告ログ）。
# DIGEST_DISPLAY_TIMEZONE=UTC
