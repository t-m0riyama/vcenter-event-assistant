# Copy to .env and adjust. See Settings in src/vcenter_event_assistant/settings.py

# --- Database (pick one) ---

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/vcenter_event_assistant

# SQLite file (single-node / dev; ensure aiosqlite is installed — included in project deps)
DATABASE_URL=sqlite+aiosqlite:///./data/vea.db

# SQLite in-memory (tests / ephemeral)
# DATABASE_URL=sqlite+aiosqlite:///:memory:

# SCHEDULER_ENABLED=true
# CORS_ORIGINS=http://localhost:5173

# --- Data retention (days; purge runs on a schedule) ---
# EVENT_RETENTION_DAYS=7
# METRIC_RETENTION_DAYS=7

# --- Batch digest (Markdown; optional LLM summary) ---
# APScheduler での自動生成（`SCHEDULER_ENABLED=true` かつアプリ起動時にスケジューラが載ること）
#
# 日次・週次・月次はそれぞれ ON/OFF と cron を個別指定（推奨）
# DIGEST_DAILY_ENABLED=false
# DIGEST_DAILY_CRON=0 7 * * *
# DIGEST_WEEKLY_ENABLED=false
# 例: 毎週日曜 8:00（5 フィールド: 分 時 日 月 曜）。本リポの APScheduler で `from_crontab` の曜日 0 が日曜扱いになることを `uv run python` で次回発火を UTC 変換して確認済み（環境 TZ により見かけ時刻は変わるため、運用では意図した暦日をログで要確認）
# DIGEST_WEEKLY_CRON=0 8 * * 0
# DIGEST_MONTHLY_ENABLED=false
# 例: 毎月 1 日 00:05 UTC
# DIGEST_MONTHLY_CRON=5 0 1 * *
#
# 後方互換（非推奨）: 下記は日次の実効有効/cron にマップされる（`effective_digest_daily_*`）
# DIGEST_SCHEDULER_ENABLED=false
# DIGEST_CRON=0 7 * * *

# LLM（省略時はテンプレートのみ。ホスト名・VM 名などが外部 API に送られる可能性あり）
# LLM_PROVIDER=openai_compatible
# LLM_PROVIDER=gemini
# LLM_API_KEY=
# OpenAI 互換時のみ
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
# Gemini 時は Google AI Studio のキーを LLM_API_KEY に。例: gemini-2.0-flash
# LLM_TIMEOUT_SECONDS=60

# ダイジェスト本文の Jinja2 テンプレ（省略時はパッケージ同梱の digest.md.j2）
# 解決順: DIGEST_TEMPLATE_PATH（非空かつファイルでない場合はエラー・DIR には落とさない）
#   → DIGEST_TEMPLATE_DIR + DIGEST_TEMPLATE_FILE（ファイル不可ならエラー・同梱には落とさない）
#   → 同梱テンプレ。各 run_digest 実行ごとにディスクから読み直す。相対パスはプロセスの cwd 基準。
# DIGEST_TEMPLATE_PATH=
# DIGEST_TEMPLATE_DIR=
# DIGEST_TEMPLATE_FILE=digest.md.j2
# 日時表示のみ。集計ウィンドウは従来どおり UTC。無効な IANA 名は UTC にフォールバックして警告ログ。
# DIGEST_DISPLAY_TIMEZONE=UTC
