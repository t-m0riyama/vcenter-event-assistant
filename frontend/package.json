{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "e2e": "npm run build && playwright test",
    "e2e:install": "playwright install",
    "screenshots": "PLAYWRIGHT_USE_EXISTING_SERVER=1 E2E_PORT=8000 E2E_RUN_SCREENSHOTS_SPEC=1 WRITE_DOC_SCREENSHOTS_TO_REPO=1 playwright test e2e/screenshots.spec.ts",
    "screenshots:spawn": "npm run build && SCREENSHOT_E2E_SEED=1 E2E_RUN_SCREENSHOTS_SPEC=1 WRITE_DOC_SCREENSHOTS_TO_REPO=1 playwright test e2e/screenshots.spec.ts"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "1.58.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "happy-dom": "^20.0.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^5.4.11",
    "vitest": "^3.2.4"
  }
}
